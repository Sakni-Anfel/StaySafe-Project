<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#16425B"
    tools:context=".main">

    <!-- Top decorative circle blob -->
    <View
        android:layout_width="380dp"
        android:layout_height="380dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-120dp"
        android:layout_marginEnd="-120dp"
        android:background="@drawable/blob_circle_light"
        android:alpha="0.15" />

    <!-- Second smaller blob -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="top|start"
        android:layout_marginTop="60dp"
        android:layout_marginStart="-60dp"
        android:background="@drawable/blob_circle_light"
        android:alpha="0.08" />

    <!-- Horizontal accent line -->
    <View
        android:layout_width="60dp"
        android:layout_height="3dp"
        android:layout_gravity="top|start"
        android:layout_marginTop="64dp"
        android:layout_marginStart="32dp"
        android:background="@drawable/rounded_bar"
        android:alpha="0.5" />

    <!-- Top label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginTop="80dp"
        android:layout_marginStart="32dp"
        android:text="STAY SAFE"
        android:textColor="#CCBFDBF7"
        android:textSize="11sp"
        android:letterSpacing="0.25"
        android:fontFamily="sans-serif-medium" />

    <!-- Center illustration area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="120dp"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Big wave emoji as focal point -->
      <!--  <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌊"
            android:textSize="90sp"
            android:layout_marginBottom="24dp" /> -->
    <ImageView
    android:layout_width="80dp"
    android:layout_height="wrap_content"
    android:src="@drawable/floodedhouse"/>
        <!-- Decorative dots row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/blob_circle_light"
                android:alpha="0.3"
                android:layout_marginEnd="6dp" />

            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/blob_circle_light"
                android:alpha="0.6" />

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/blob_circle_light"
                android:alpha="0.3"
                android:layout_marginStart="6dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Bottom content anchored -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingBottom="56dp">

        <!-- Card with title + subtitle -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1F5470"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="24dp"
                android:paddingBottom="24dp">

                <!-- Tag line -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FLOOD DETECTION SYSTEM"
                    android:textColor="#88A1C6EA"
                    android:textSize="10sp"
                    android:letterSpacing="0.2"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="10dp" />

                <!-- Main title -->
                <TextView
                    android:id="@+id/app_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stay Safe"
                    android:textColor="#FFFFFF"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/textbold"
                    android:lineSpacingMultiplier="0.95"
                    android:layout_marginBottom="10dp" />

                <!-- Divider line -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="2dp"
                    android:background="#81C3D7"
                    android:layout_marginBottom="12dp" />

                <!-- Subtitle -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Real-time alerts and safety guidance when it matters most."
                    android:textColor="#CCBFDBF7"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.5"
                    android:fontFamily="sans-serif" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Get Started button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/usertype"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Get Started"
            android:textSize="17sp"
            android:textColor="#16425B"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:fontFamily="@font/textbold"
            app:backgroundTint="#a1c6ea"
            app:cornerRadius="14dp"
            android:elevation="0dp"
            android:layout_marginBottom="16dp" />

        <!-- Bottom tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Your safety is our priority"
            android:textColor="#55BFDBF7"
            android:textSize="12sp"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.05" />

    </LinearLayout>

</FrameLayout>