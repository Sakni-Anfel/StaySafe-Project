<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#BFDBF7"
    android:fillViewport="true">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Top half background -->
        <View
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:background="#BFDBF7" />

        <!-- Bottom half background -->
        <View
            android:layout_width="match_parent"
            android:layout_height="900dp"
            android:layout_marginTop="280dp"
            android:background="#16425B" />

        <!-- Diagonal divider -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="230dp"
            android:src="@drawable/diagonal_divider"
            android:scaleType="fitXY" />

        <!-- Full content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="56dp"
            android:paddingBottom="48dp">

            <!-- Branding -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="40dp"
                    android:background="@drawable/rounded_bar"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stay Safe"
                        android:textColor="#16425B"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Flood Detection System"
                        android:textColor="#6616425B"
                        android:textSize="11sp"
                        android:letterSpacing="0.12"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/floodedhousemini"
                    android:layout_marginLeft="90dp"
                    android:layout_weight="1" />

            </LinearLayout>

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="My"
                android:textColor="#16425B"
                android:textSize="42sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="account"
                android:textColor="#8816425B"
                android:textSize="16sp"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="32dp" />

            <!-- Profile avatar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginBottom="24dp">


            </LinearLayout>

            <!-- Info card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="12dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="28dp"
                    android:paddingBottom="28dp">

                    <!-- Full Name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FULL NAME"
                        android:textColor="#A1C6EA"
                        android:textSize="10sp"
                        android:letterSpacing="0.18"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxStrokeColor="#A1C6EA"
                        app:boxStrokeWidth="1.5dp"
                        app:boxBackgroundColor="#F7FBFF"
                        app:hintTextColor="#A1C6EA"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        android:layout_marginBottom="22dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/fullNameProfil"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Full name"
                            android:inputType="textPersonName"
                            android:textColor="#16425B"
                            android:textColorHint="#88A1C6EA"
                            android:paddingTop="16dp"
                            android:paddingBottom="16dp"
                            android:fontFamily="sans-serif" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Email -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EMAIL ADDRESS"
                        android:textColor="#A1C6EA"
                        android:textSize="10sp"
                        android:letterSpacing="0.18"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxStrokeColor="#A1C6EA"
                        app:boxStrokeWidth="1.5dp"
                        app:boxBackgroundColor="#F7FBFF"
                        app:hintTextColor="#A1C6EA"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        android:layout_marginBottom="22dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/emailProfile"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="you@example.com"
                            android:inputType="textEmailAddress"
                            android:textColor="#16425B"
                            android:textColorHint="#88A1C6EA"
                            android:paddingTop="16dp"
                            android:paddingBottom="16dp"
                            android:fontFamily="sans-serif" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Phone -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EMERGENCY PHONE NUMBER"
                        android:textColor="#A1C6EA"
                        android:textSize="10sp"
                        android:letterSpacing="0.18"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxStrokeColor="#A1C6EA"
                        app:boxStrokeWidth="1.5dp"
                        app:boxBackgroundColor="#F7FBFF"
                        app:hintTextColor="#A1C6EA"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        android:layout_marginBottom="4dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/phoneNumber"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="+216 24 567 890"
                            android:inputType="phone"
                            android:textColor="#16425B"
                            android:textColorHint="#88A1C6EA"
                            android:paddingTop="16dp"
                            android:paddingBottom="16dp"
                            android:fontFamily="sans-serif" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Edit button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/editProfile"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Save Changes"
                android:textSize="17sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.04"
                app:backgroundTint="#a1c6ea"
                app:cornerRadius="16dp"
                android:layout_marginBottom="12dp" />

            <!-- Logout button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/logOut"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Log Out"
                android:textSize="17sp"
                android:textColor="#a1c6ea"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.04"
                app:backgroundTint="#1A2A35"
                app:strokeColor="#a1c6ea"
                app:strokeWidth="1.5dp"
                app:cornerRadius="16dp"
                android:layout_marginBottom="20dp" />

        </LinearLayout>
    </FrameLayout>
</ScrollView>