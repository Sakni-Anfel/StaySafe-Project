<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drop_usertype"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#16425B">

    <!-- Soft top accent circle (decorative) -->
    <View
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="-150dp"
        android:background="@drawable/circle_accent" />

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:src="@drawable/floodedhouse"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"/>


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Who are you?"
            android:textColor="#BFDBF7"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Select your role to continue"
            android:textColor="#80A1C3D7"
            android:textSize="14sp"
            android:fontFamily="sans-serif"
            android:layout_marginBottom="48dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/user"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:text="I'm a User"
            android:textSize="16sp"
            android:textColor="#16425B"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.03"
            app:backgroundTint="#a1c6ea"
            app:cornerRadius="14dp"
            android:elevation="0dp"
            android:layout_marginBottom="16dp" />

        <!-- Admin Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/admin"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:text="I'm an Admin"
            android:textSize="16sp"
            android:textColor="#BFDBF7"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.03"
            app:backgroundTint="#1F5470"
            app:cornerRadius="14dp"
            app:strokeColor="#a1c6ea"
            app:strokeWidth="1.5dp"
            android:elevation="0dp" />

    </LinearLayout>

</FrameLayout>